---
// Base HTML shell for every page: sets <head> metadata (title, description, OG
// tags, favicon), the /fiducia base URL, and renders page content via <slot />.
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Fiducia — Consensus & Coordination as a Service',
  description = 'Fiducia is a Raft-based consensus and coordination platform for distributed systems and AI-agent fleets: locks, semaphores, task claims, rate limiting, shared state, elections, KV watches, and reliable cron.',
} = Astro.props;

// Normalize BASE_URL to always end in exactly one slash (Astro returns it
// without a trailing slash when `base` is configured without one).
const base = import.meta.env.BASE_URL.replace(/\/+$/, '') + '/';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <!-- Privacy hardening: don't leak full URLs/paths to third-party origins.
         HTTP security headers (CSP, X-Content-Type-Options, X-Frame-Options,
         Referrer-Policy) are set by the serving layer (fiducia-customer.rs). -->
    <meta name="referrer" content="strict-origin-when-cross-origin" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#070b1a" />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <title>{title}</title>
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
  </head>
  <body>
    <slot />
  </body>
</html>
